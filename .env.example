# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin ID (from @userinfobot)
ADMIN_ID=123456789

# Database URL (Neon.tech PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname

# Environment: development (polling) or production (webhook)
ENVIRONMENT=development

# Webhook URL (for production on Deno Deploy)
# Example: https://your-project.deno.dev
WEBHOOK_URL=https://your-project.deno.dev
